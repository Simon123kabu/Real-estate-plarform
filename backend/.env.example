# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production

# ── Database ─────────────────────────────────────────────────────────────────
# Get from MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/real_estate_db

# ── Session ───────────────────────────────────────────────────────────────────
# Must be a long, random, private string. Changing it invalidates all sessions.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_secret_string

# ── CORS ──────────────────────────────────────────────────────────────────────
# The URL of your frontend — no trailing slash
CLIENT_URL=http://localhost:5173

# ── Cloudinary (image uploads) ────────────────────────────────────────────────
# Get from https://console.cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ── Admin Seed (one-time setup) ───────────────────────────────────────────────
# Used by: node src/scripts/seedAdmin.js
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_a_strong_password

# ── Paystack (Payment Integration) ───────────────────────────────────────────
# Get from Paystack Dashboard → Settings → API Keys & Webhooks (use test keys)
PAYSTACK_SECRET_KEY=your_paystack_test_secret_key_here
PAYSTACK_PLAN_PREMIUM=your_paystack_premium_plan_code_here
PAYSTACK_PLAN_PREMIUM_PLUS=your_paystack_premium_plus_plan_code_here

# ── Email Settings (Gmail SMTP) ────────────────────────────────────────────────
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password_here